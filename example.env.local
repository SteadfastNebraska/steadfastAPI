NODE_ENV="development" || "production" #development = use DEV_EMAIL_TO for all emails
MONGODB_URI="my_mongo_endpoint" #this is the endpoint (URL or IP) for your mongoDb instance
MONGO_PASSWORD="my_mongo_password" #this is the password for your mongoDb instance
MONGO_USERNAME="my_mongo_username" #this is the username for your mongoDb instance
MAILGUN_APIKEY="my_mailgun_api_key" #this is the api key for your mailgun account
MAILGUN_DOMAIN="mg.my_school_domain.org" #this is the domain for your mailgun account
DEV_EMAIL_TO="me.dev@my_school_domain.org" #this is the email address to use for development emails
SITE_URL="localhost:3000" #this is the url for your site
AUTHTOKEN="my_auth_token" #this is the authentication token for your API